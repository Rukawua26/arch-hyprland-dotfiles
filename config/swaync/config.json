{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "user",
  "notification-window-width": 420,
  "notification-window-height": -1,
  "control-center-width": 460,
  "control-center-height": 720,
  "control-center-margin-top": 12,
  "control-center-margin-right": 12,
  "control-center-layer": "overlay",
  "hide-on-clear": false,
