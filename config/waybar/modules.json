{
  "custom/arch": {
    "format": "у∞£З",
    "tooltip": true,
    "tooltip-format": "btw"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}",
    "format-icons": {
      "urgent": "пБ™",
      "active": "пЖТ",
      "default": "пДС"
    }
  },
  "hyprland/window": {
    "max-length": 48,
    "separate-outputs": true
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пБЃ",
      "deactivated": "пБ∞"
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}% пКФ {format_source}",
    "format-bluetooth-muted": "ођ§  {icon} пКФ {format_source}",
    "format-muted": "у∞ЛР {format_source}",
    "format-source": "пД∞ {volume}%",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "оєЩ",
      "headset": "оєЩ",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": ["пА¶", "пАІ", "пА®"]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format-wifi": "у∞§® {signalStrength}%",
    "format-ethernet": "у∞ИА {ifname}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Sin red",
    "format-linked": "у∞ИА {ifname}",
    "format-disconnected": "у∞Ц™",
    "on-click": "kitty -e nmtui"
  },
  "custom/bluetooth": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/bluetooth.sh status",
    "interval": 5,
    "return-type": "json",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/bluetooth.sh menu",
    "on-click-right": "~/.config/waybar/scripts/bluetooth.sh power",
    "on-click-middle": "~/.config/waybar/scripts/bluetooth.sh scan"
  },
  "custom/network": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/network.sh",
    "interval": 5,
    "on-click": "~/.config/waybar/scripts/network.sh menu",
    "on-click-right": "~/.config/waybar/scripts/network.sh toggle",
    "on-click-middle": "~/.config/waybar/scripts/network.sh scan",
    "tooltip": true,
    "return-type": "json"
  },
  "cpu": {
    "format": "пЛЫ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "пГЙ  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "пЛЗ {temperatureC}",
    "format": "пЛЙ {temperatureC}¬∞C"
  },
  "hyprland/language": {
    "format": "пВђ {}",
    "format-en": "EN",
    "format-es": "ES"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}% {time}",
    "format-full": "{icon} {capacity}%",
    "format-charging": "пЗ¶ {capacity}%",
    "format-plugged": "пЗ¶ {capacity}%",
    "format-alt": "{icon} {capacity}%",
    "tooltip-format": "{power}W ¬Ј {capacity}% ¬Ј {time}",
    "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%a %d %b %H:%M}"
  }
}
